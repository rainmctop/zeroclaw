venv/
.pytest_cache/
.mypy_cache/
.tox/

# Temp files
*.tmp
*~
.DS_Store
Thumbs.db

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
